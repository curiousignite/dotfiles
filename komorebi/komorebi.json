{
    "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.28/schema.json",
    "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.yaml",
    "window_hiding_behaviour": "Cloak",
    "cross_monitor_move_behaviour": "Insert",
    "animation": {
        "enabled": true,
        "duration": 150
    },
    "default_workspace_padding": 3,
    "default_container_padding": 3,
    "border": true,
    "border_width": 5,
    "border_offset": -1,
    "border_colours": {
        "single": "#cba6f7",
        "stack": "#a6e3a1",
        "monocle": "#f5c2e7",
        "unfocused": "#1e1e2e"
    },
    "stackbar": {
        "height": 40,
        "mode": "OnStack",
        "tabs": {
            "width": 300,
            "focused_text": "#00a542",
            "unfocused_text": "#b3b3b3",
            "background": "#141414"
        }
    },
    "monitors": [
        {
            "workspaces": [
                {
                    "name": "I",
                    "layout": "BSP"
                },
                {
                    "name": "II",
                    "layout": "VerticalStack"
                },
                {
                    "name": "III",
                    "layout": "HorizontalStack"
                },
                {
                    "name": "IV",
                    "layout": "UltrawideVerticalStack"
                },
                {
                    "name": "V",
                    "layout": "Rows"
                },
                {
                    "name": "VI",
                    "layout": "Grid"
                },
                {
                    "name": "VII",
                    "layout": "RightMainVerticalStack"
                }
            ]
        }
    ]
}
